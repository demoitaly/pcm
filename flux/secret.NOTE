dal manager :
kubectl get secret -n cert-manager kommander-ca -o jsonpath='{.data.ca\.crt}' | base64 -d > ca.crt

dal workload dentro il namespcaper dove crei gli ogetti flux

kubectl create secret docker-registry docker-imagepull-secret   --docker-server=10.38.36.43:5000   --docker-username='admin'   --docker-password='jrFMokKndoZDvwllWVsC'   --docker-email='tuamail@example.com'   -n demo   --dry-run=client -o yaml | kubectl apply -f -
kubectl create secret generic harbor-ca   --from-file=ca.crt=./ca.crt   -n demo   --dry-run=client -o yaml | kubectl apply -f -
